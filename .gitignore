# Dependencies
node_modules/

# pnpm: local content-addressable store when store-dir is inside the repo (very large; never commit)
.pnpm-store/

# Build outputs
dist/
build/

# Turbo cache
.turbo/

# TypeScript incremental build
*.tsbuildinfo

# Stale tsc output emitted alongside source (outDir should be dist/)
# Only ignore compiler-generated maps; hand-written .d.ts (e.g. ambient type
# declarations) and .js source files are intentionally NOT ignored here.
packages/*/src/**/*.d.ts.map
packages/*/src/**/*.js.map

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/

# Tool caches
.eslintcache
.prettiercache

# Packed tarballs (npm pack / local publishes)
*.tgz

# Local scratch
scratch/
tmp/
.tmp/
__tmp_*/

# Claude AI context
.claude/

# Planning files
plan/


