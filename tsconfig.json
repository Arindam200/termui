      "@termui/adapters/pty": ["packages/adapters/pty/index.ts"],
      "@termui/adapters/execa": ["packages/adapters/execa/index.ts"],
      "@termui/adapters/link": ["packages/adapters/link/index.ts"],
      "@termui/adapters/semver-update": ["packages/adapters/semver-update/index.ts"],
      "@termui/adapters/conf": ["packages/adapters/conf/index.ts"],
      "@termui/adapters/completion": ["packages/adapters/completion/index.ts"],
      "@termui/adapters/internal/color-env": ["packages/adapters/internal/color-env.ts"],
      "@termui/adapters/chalk": ["packages/adapters/chalk/index.ts"],
      "@termui/adapters/commander": ["packages/adapters/commander/index.ts"],
      "@termui/adapters/imperative": ["packages/adapters/imperative/index.ts"],
