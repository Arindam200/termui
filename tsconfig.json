      "@termui/components/typography": ["packages/components/src/typography/index.ts"],
      "@termui/components/input": ["packages/components/src/input/index.ts"],
      "@termui/components/selection": ["packages/components/src/selection/index.ts"],
      "@termui/components/data": ["packages/components/src/data/index.ts"],
      "@termui/components/feedback": ["packages/components/src/feedback/index.ts"],
      "@termui/components/navigation": ["packages/components/src/navigation/index.ts"],
      "@termui/components/overlays": ["packages/components/src/overlays/index.ts"],
      "@termui/components/forms": ["packages/components/src/forms/index.ts"],
      "@termui/components/utility": ["packages/components/src/utility/index.ts"],
      "@termui/components/charts": ["packages/components/src/charts/index.ts"],
      "@termui/components/templates": ["packages/components/src/templates/index.ts"],
      "@termui/components/ai": ["packages/components/src/ai/index.ts"],
      "@termui/adapters/ai": ["packages/adapters/ai/index.ts"],
      "@termui/adapters/conversation-store": ["packages/adapters/conversation-store/index.ts"],
      "@termui/adapters/args": ["packages/adapters/args/index.ts"],
      "@termui/adapters/clack": ["packages/adapters/clack/index.ts"],
      "@termui/adapters/clack-ink": ["packages/adapters/clack-ink/index.tsx"],
      "@termui/adapters/picocolors": ["packages/adapters/picocolors/index.ts"],
      "@termui/adapters/gray-matter": ["packages/adapters/gray-matter/index.ts"],
      "@termui/adapters/git": ["packages/adapters/git/index.ts"],
