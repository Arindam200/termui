{
  "name": "termui",
  "private": false,
  "version": "1.4.1",
  "description": "A TypeScript/React terminal UI framework with 100+ components, 8 themes, and a shadcn-style CLI",
  "keywords": [
    "terminal",
    "tui",
    "cli",
    "react",
    "ink",
    "typescript",
    "components"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Arindam200/termui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arindam200/termui.git"
  },
  "bugs": {
    "url": "https://github.com/Arindam200/termui/issues"
  },
  "type": "module",
  "bin": {
    "termui": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./components": {
      "import": "./dist/components.js",
      "types": "./dist/components.d.ts"
    },
    "./components/layout": {
      "import": "./dist/components-layout.js",
      "types": "./dist/components-layout.d.ts"
    },
    "./components/typography": {
      "import": "./dist/components-typography.js",
      "types": "./dist/components-typography.d.ts"
    },
    "./components/input": {
      "import": "./dist/components-input.js",
      "types": "./dist/components-input.d.ts"
    },
    "./components/selection": {
      "import": "./dist/components-selection.js",
      "types": "./dist/components-selection.d.ts"
    },
    "./components/data": {
      "import": "./dist/components-data.js",
      "types": "./dist/components-data.d.ts"
    },
    "./components/feedback": {
      "import": "./dist/components-feedback.js",
      "types": "./dist/components-feedback.d.ts"
    },
    "./components/navigation": {
      "import": "./dist/components-navigation.js",
      "types": "./dist/components-navigation.d.ts"
    },
    "./components/overlays": {
      "import": "./dist/components-overlays.js",
      "types": "./dist/components-overlays.d.ts"
    },
    "./components/forms": {
      "import": "./dist/components-forms.js",
      "types": "./dist/components-forms.d.ts"
    },
    "./components/utility": {
      "import": "./dist/components-utility.js",
      "types": "./dist/components-utility.d.ts"
    },
    "./components/charts": {
      "import": "./dist/components-charts.js",
      "types": "./dist/components-charts.d.ts"
    },
    "./components/templates": {
      "import": "./dist/components-templates.js",
      "types": "./dist/components-templates.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks.js",
      "types": "./dist/hooks.d.ts"
    },
    "./args": {
      "import": "./dist/args.js",
      "types": "./dist/args.d.ts"
    },
    "./clack": {
      "import": "./dist/clack.js",
      "types": "./dist/clack.d.ts"
    },
    "./clack-ink": {
      "import": "./dist/clack-ink.js",
      "types": "./dist/clack-ink.d.ts"
    },
    "./picocolors": {
      "import": "./dist/picocolors.js",
      "types": "./dist/picocolors.d.ts"
    },
    "./gray-matter": {
      "import": "./dist/gray-matter.js",
      "types": "./dist/gray-matter.d.ts"
    },
    "./git": {
      "import": "./dist/git.js",
      "types": "./dist/git.d.ts"
    },
    "./github": {
      "import": "./dist/github.js",
      "types": "./dist/github.d.ts"
    },
    "./keychain": {
      "import": "./dist/keychain.js",
      "types": "./dist/keychain.d.ts"
    },
    "./pty": {
      "import": "./dist/pty.js",
      "types": "./dist/pty.d.ts"
    },
    "./execa": {
      "import": "./dist/execa.js",
      "types": "./dist/execa.d.ts"
    },
    "./link": {
      "import": "./dist/link.js",
      "types": "./dist/link.d.ts"
    },
    "./semver-update": {
      "import": "./dist/semver-update.js",
      "types": "./dist/semver-update.d.ts"
    },
    "./conf": {
      "import": "./dist/conf.js",
      "types": "./dist/conf.d.ts"
    },
    "./completion": {
      "import": "./dist/completion.js",
      "types": "./dist/completion.d.ts"
    },
    "./color-env": {
      "import": "./dist/color-env.js",
      "types": "./dist/color-env.d.ts"
    },
    "./components/ai": {
      "import": "./dist/components-ai.js",
      "types": "./dist/components-ai.d.ts"
    },
    "./ai": {
      "import": "./dist/ai.js",
      "types": "./dist/ai.d.ts"
    },
    "./conversation-store": {
      "import": "./dist/conversation-store.js",
      "types": "./dist/conversation-store.d.ts"
    },
    "./chalk": {
      "import": "./dist/chalk.js",
      "types": "./dist/chalk.d.ts"
    },
    "./ora": {
      "import": "./dist/ora.js",
      "types": "./dist/ora.d.ts"
    },
    "./meow": {
      "import": "./dist/meow.js",
      "types": "./dist/meow.d.ts"
    },
    "./commander": {
      "import": "./dist/commander.js",
      "types": "./dist/commander.d.ts"
    },
    "./inquirer": {
      "import": "./dist/inquirer.js",
      "types": "./dist/inquirer.d.ts"
    },
    "./imperative": {
      "import": "./dist/imperative.js",
      "types": "./dist/imperative.d.ts"
    },
    "./svelte": {
      "import": "./dist/svelte.js",
      "types": "./dist/svelte.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.js",
      "types": "./dist/vue.d.ts"
    }
  },
  "dependencies": {
    "latest-version": "^9.0.0",
    "semver": "^7.6.0",
    "strip-ansi": "^7.1.0"
  },
  "peerDependencies": {
    "ink": "^5.0.0",
    "react": "^18.0.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "turbo run build && tsup",
    "build:root": "tsup && chmod +x dist/cli.js",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "release": "pnpm run build && pnpm publish -r --no-git-checks",
    "version": "pnpm changeset version",
    "changeset": "changeset",
    "registry:check": "tsx scripts/check-registry-versions.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cross-env": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "author": {
    "name": "Arindam Majumder",
    "url": "https://github.com/Arindam200"
  }
}
