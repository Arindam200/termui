{
  "name": "@termui/components",
  "version": "1.1.0",
  "description": "TermUI component library — 101 terminal UI components",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@termui/core": "workspace:*",
    "ink": "^5.0.0",
    "react": "^18.0.0",
    "strip-ansi": "^7.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.0.0",
    "typescript": "^5.4.0",
    "@vitest/coverage-v8": "^1.0.0"
  }
}
