{
  "name": "@termui/types",
  "version": "1.4.1",
  "description": "Framework-agnostic TypeScript type definitions for TermUI components",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "termui",
    "types",
    "terminal",
    "cli"
  ],
  "license": "MIT"
}
