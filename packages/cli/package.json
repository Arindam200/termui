{
  "name": "termui",
  "version": "1.3.0",
  "description": "TermUI CLI — shadcn-style terminal UI component distribution",
  "type": "module",
  "bin": {
    "termui": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@termui/core": "workspace:*",
    "glob": "^11.0.0",
    "semver": "^7.6.0",
    "latest-version": "^9.0.0",
    "proper-lockfile": "^4.1.2",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@termui/testing": "workspace:*",
    "@octokit/rest": "^21.0.2",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.5.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0",
    "tsx": "^4.7.0",
    "msw": "^2.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
