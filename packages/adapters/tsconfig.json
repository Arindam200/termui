{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@termui/core": ["../core/src/index.ts"],
      "@termui/core/hooks": ["../core/src/hooks/index.ts"],
      "@termui/core/styling": ["../core/src/styling/index.ts"],
      "@termui/core/terminal": ["../core/src/terminal/index.ts"],
      "@termui/components": ["../components/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/dist", "**/*.test.ts"]
}
